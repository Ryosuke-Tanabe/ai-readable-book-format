{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-readable-book-format-v0.1.schema.json",
  "title": "AIが読む本フォーマット v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "structure",
    "content_units",
    "interpretations",
    "uncertainties",
    "relations"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "書誌情報",
      "additionalProperties": true,
      "required": ["title", "author", "genre", "language"],
      "properties": {
        "work_id": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "genre": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "mode": { "type": "string" },
        "story_type": { "type": "string" }
      }
    },

    "format_rules": {
      "type": "object",
      "description": "任意拡張。実例で使われている補助ルール群",
      "additionalProperties": true,
      "properties": {
        "content_rule": { "type": "string" },
        "confidence_scale": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowed_values": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "uniqueItems": true
            }
          }
        },
        "relation_types": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowed_values": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        }
      }
    },

    "structure": {
      "type": "object",
      "description": "本文の配置構造。意味構造ではなく章や節などの区切り",
      "additionalProperties": false,
      "required": ["units"],
      "properties": {
        "units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "title"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": {
                "type": "string",
                "minLength": 1,
                "description": "例: chapter, section, part, scene など。必須語彙ではない"
              },
              "title": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "content_units": {
      "type": "array",
      "minItems": 1,
      "description": "本文に記述されている内容の最小単位。解釈は入れない",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "location", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "minLength": 1,
            "description": "recommended vocabulary を含むが、必須語彙ではない",
            "$comment": "Recommended: state, event, observation, statement, outcome, condition, trigger, reflection"
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "description": "structure.units.id を参照する想定"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "what is stated, observed, or explicitly reported; not inferred meaning"
          }
        }
      }
    },

    "interpretations": {
      "type": "array",
      "description": "主体付きの解釈レコード",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "agent", "target", "claim", "confidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "agent": {
            "type": "string",
            "enum": ["narrator", "reader", "critic"]
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "content_units.id または relations.id を参照する想定"
          },
          "claim": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },

    "uncertainties": {
      "type": "array",
      "description": "不確定性を保存する層",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "type", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "content_units.id または relations.id を参照する想定"
          },
          "type": {
            "type": "string",
            "enum": [
              "causal_unknown",
              "mechanism_unknown",
              "evidence_missing",
              "witness_unavailable",
              "scope_unknown",
              "interpretation_conflict"
            ]
          },
          "reason": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1
              }
            ]
          }
        }
      }
    },

    "relations": {
      "type": "array",
      "description": "content_units 間の関係",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "target", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "content_units.id を参照する想定"
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "content_units.id を参照する想定"
          },
          "type": {
            "type": "string",
            "enum": [
              "temporal_sequence",
              "explicit_cause",
              "possible_cause",
              "retrospective_link",
              "contrast",
              "thematic_echo"
            ]
          }
        }
      }
    },

    "aftertaste": {
      "type": "object",
      "description": "任意拡張。小説実例にある余韻レイヤー",
      "additionalProperties": true,
      "properties": {
        "emotional_residue": {
          "type": "array",
          "items": { "type": "string" }
        },
        "final_state": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "gain": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unresolved_domain": {
              "type": "array",
              "items": { "type": "string" }
            },
            "relation_status": { "type": "string" }
          }
        }
      }
    }
  }
}